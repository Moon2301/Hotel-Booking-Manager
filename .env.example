# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Docker compose overrides POSTGRES_HOST=postgres, REDIS_HOST=redis for service "dev"
# API_PORT=3000
# WEB_ADMIN_PORT=3001
# WEB_CLIENT_PORT=8080

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hotel_user
POSTGRES_PASSWORD=hotel_secret
POSTGRES_DB=hotel_db
DATABASE_URL=postgresql://hotel_user:hotel_secret@localhost:5432/hotel_db

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# pgAdmin (docker profile: tools)
# ─────────────────────────────────────────
PGADMIN_EMAIL=admin@hotel.com
PGADMIN_PASSWORD=pgadmin_secret
PGADMIN_PORT=5050

# ─────────────────────────────────────────
# Booking Engine
# ─────────────────────────────────────────
HOLD_TTL_SECONDS=600          # 600-900 per property config

# ─────────────────────────────────────────
# Payment Webhook
# ─────────────────────────────────────────
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_webhook_hmac_secret

# ─────────────────────────────────────────
# Expo Push (Notifications)
# ─────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:8080,http://localhost:3000

# ─────────────────────────────────────────
# Public URLs (VNPay redirect)
# API_PUBLIC_URL: URL mà VNPay/trình duyệt gọi callback (map port Docker → host)
# CLIENT_URL: Web client — redirect khách sau thanh toán
# ─────────────────────────────────────────
API_PUBLIC_URL=http://localhost:3000
CLIENT_URL=http://localhost:8080
CLIENT_PAYMENT_PATH=/my-stay

# ─────────────────────────────────────────
# VNPay (Sandbox)
# ─────────────────────────────────────────
VNP_TMNCODE=R4923J2J
VNP_HASHSECRET=P68JKLG8376RKRTBPWCKDD7XR3OYF4TZ
VNP_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# true = thanh toán giả lập local (tránh lỗi VNPay "website chưa phê duyệt")
VNP_MOCK=true

# ─────────────────────────────────────────
# Mã QR / xác thực đặt phòng — SHA-256(bookingId:secret)
# ─────────────────────────────────────────
BOOKING_QR_SECRET=your_random_secret_min_32_chars

# ─────────────────────────────────────────
# Email (SMTP) — dùng Gmail hoặc Mailtrap sandbox
# ─────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
