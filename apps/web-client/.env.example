# Proxy API requests to NestJS (local or Docker mapped port)
VITE_API_PROXY_TARGET=http://localhost:3000

# Public guest site URL (optional — used in My Stay wrong-port hint)
VITE_PUBLIC_SITE_URL=http://localhost:8080

# Mạng xã hội (footer) — đặt "off" để ẩn một mục
# VITE_FACEBOOK_URL=https://www.facebook.com/your-page
